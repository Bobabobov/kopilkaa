// prisma/schema.prisma
datasource db {
  provider = "sqlite" // если решишь перейти на Postgres — скажешь, переделаем URL/миграции
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

/**
 * Категория запрашиваемой помощи (шаг формы и требования к фото)
 */
enum ApplicationCategory {
  FOOD_DRINKS
  HOUSEHOLD_ESSENTIALS
  TRANSPORT_COMMS
  SMALL_GIFT
  EVERYDAY_SUPPORT
  /**
   * Значение из старых БД; в форме не используется, нужно для чтения заявок
   */
  GAME_OR_SERVICE
}

enum GoodDeedSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GoodDeedMediaType {
  IMAGE
  VIDEO
}

model User {
  id                   String    @id @default(cuid())
  email                String?   @unique
  username             String?   @unique
  passwordHash         String
  name                 String?
  avatar               String?
  avatarUpdatedAt      DateTime?
  phone                String?   @unique
  phoneVerified        Boolean   @default(false)
  /**
   * Подтверждение владения email (регистрация по паролю); OAuth/Telegram выставляют true при создании.
   */
  emailVerified        Boolean   @default(false)
  telegramId           String?   @unique
  telegramUsername     String?
  googleId             String?   @unique
  googleEmail          String?
  vkLink               String?
  telegramLink         String?
  youtubeLink          String?
  referralCode         String?   @unique // уникальный код для реферальной программы
  headerTheme          String?   @default("default")
  headerThemeUpdatedAt DateTime?
  /// Своя обложка профиля (URL загрузки), видна всем пользователям
  headerCover          String?
  headerDominantColor  String? // Доминантный цвет из обложки
  avatarFrame          String?   @default("none")
  customFrameData      String? // JSON данные пользовательских рамок
  // Ручной override для уникального HERO_BADGE (используется только для оплат > 5000).
  // Примеры значений: "custom" (или любое непустое значение как флаг).
  heroBadgeOverride    String?
  // Если true — пользователь скрыт из витрины /heroes (история поддержек не удаляется).
  hideFromHeroes       Boolean   @default(false)
  hideEmail            Boolean   @default(true) // Скрывать email в профиле по умолчанию
  role                 String    @default("USER")
  createdAt            DateTime  @default(now())
  lastSeen             DateTime  @default(now())
  lastCommentAt        DateTime? // Время последнего комментария для кулдауна
  /// Админ может запретить вывод бонусов (заявки на вывод отклоняются на стороне UI).
  bonusWithdrawalBlocked Boolean   @default(false)
  /// До 3 slug ачивок для отображения в шапке профиля (JSON-массив строк).
  profileAchievementPins          Json?
  /// Уровень пользователя (механики начисления опыта — отдельно).
  level                           Int       @default(1)
  /// Накопленный опыт (в БД — в половинках: stored / 2 = отображаемый опыт).
  experience                      Int       @default(0)
  /// Бонусы, вложенные пользователем в опыт уровня (1 бонус = 0,5 опыта).
  bonusesInvestedInExperience     Int       @default(0)
  /// Последний сброс уровня админом: траты бонусов и заявки считаются только после этой даты.
  adminEconomyResetAt             DateTime?
  /// Лучший результат в игре «Секретная последовательность» (длина пройденной цепочки).
  maxSequenceRecord               Int       @default(0)

  applications                    Application[]
  userTree                        UserTree?
  referralClicks                  ReferralClick[]             @relation("ReferralClickReferrer")
  referralRegistrations           ReferralRegistration[]      @relation("ReferralRegistrationReferrer")
  referralRegistrationsAsReferred ReferralRegistration[]      @relation("ReferralRegistrationReferred")
  friendshipsSent                 Friendship[]                @relation("FriendshipRequester")
  friendshipsReceived             Friendship[]                @relation("FriendshipReceiver")
  pageVisits                      PageVisit[]
  storyLikes                      StoryLike[]
  storyComments                   StoryComment[]
  storyCommentLikes               StoryCommentLike[]
  donations                       Donation[]
  phoneLoginCodes                 PhoneLoginCode[]
  emailVerificationTokens         EmailVerificationToken[]
  reviews                         Review[]
  goodDeedSubmissions             GoodDeedSubmission[]        @relation("GoodDeedAuthor")
  goodDeedWeekPreferences         GoodDeedWeekPreference[]
  goodDeedWithdrawalRequests      GoodDeedWithdrawalRequest[] @relation("GoodDeedWithdrawalRequester")
  goodDeedBonusGrants             GoodDeedBonusGrant[]        @relation("GoodDeedBonusGrantRecipient")
  reviewedGoodDeeds               GoodDeedSubmission[]        @relation("GoodDeedReviewer")
  reviewedGoodDeedWithdrawals     GoodDeedWithdrawalRequest[] @relation("GoodDeedWithdrawalReviewer")
  grantedGoodDeedBonuses          GoodDeedBonusGrant[]        @relation("GoodDeedBonusGrantAdmin")
  dailyBonusState                 DailyBonusState?
  dailyBonusClaims                DailyBonusClaim[]
  dailyChestState                 DailyChestState?
  dailyChestClaims                DailyChestClaim[]
  userAchievements                UserAchievement[]
  loginStreakState                LoginStreakState?
  isBanned                        Boolean                     @default(false)
  bannedUntil                     DateTime?
  bannedReason                    String?

  tontineParticipations           TontineParticipant[]
  tontineWins                     TontineRound[]              @relation("TontineRoundWinner")

  dismissedStatusNotifications    DismissedStatusNotification[]
  userNotifications               UserNotification[]
  bonusTransactions               BonusTransaction[]
  dailyQuests                     UserDailyQuests?
  siteFeedback                    SiteFeedback[]
}

/// Журнал операций с бонусами (списания за заявки и др.)
model BonusTransaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Положительное число — списание бонусов
  amount        Int
  type          String
  description   String
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([applicationId])
  @@index([type])
  @@index([createdAt])
}

/// Ежедневные игровые квесты (3 контракта в сутки, сброс по UTC-дню).
model UserDailyQuests {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest1_done     Boolean  @default(false)
  quest2_done     Boolean  @default(false)
  quest3_done     Boolean  @default(false)
  questDayKey     String?
  rerollsUsed     Int      @default(0)
  quest1_type     String?
  quest1_target   Int?
  quest2_type     String?
  quest2_target   Int?
  quest3_type     String?
  quest3_target   Int?
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

/// Решения админа (одобрение/отказ) — источник правды для модалки и ленты.
model UserNotification {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String
  entityId         String
  status           String
  title            String
  message          String
  adminComment     String?
  payload          String?
  modalDismissedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, type, entityId])
  @@index([userId, modalDismissedAt])
  @@index([userId, createdAt])
}

/// @deprecated — заменено на UserNotification.modalDismissedAt
model DismissedStatusNotification {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationId String
  dismissedAt    DateTime @default(now())

  @@unique([userId, notificationId])
  @@index([userId])
}

// Реферальная программа: фиксируем клики по ссылке и успешную регистрацию по этой ссылке.
model ReferralClick {
  id             String   @id @default(cuid())
  referrerUserId String
  referrer       User     @relation("ReferralClickReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  visitorId      String // идентификатор “посетителя” из cookie
  createdAt      DateTime @default(now())

  @@unique([referrerUserId, visitorId])
  @@index([referrerUserId])
  @@index([createdAt])
}

model ReferralRegistration {
  id             String    @id @default(cuid())
  referrerUserId String
  referrer       User      @relation("ReferralRegistrationReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredUserId String    @unique
  referredUser   User      @relation("ReferralRegistrationReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  visitorId      String // тот же visitorId из cookie, чтобы начислять максимум 1 бонус на “человека” с одного устройства
  createdAt      DateTime  @default(now())
  bonusGrantedAt DateTime?

  @@index([referrerUserId])
}

model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                    String
  summary                  String
  story                    String
  /**
   * Категория помощи — влияет на подсказки к фото до заявки и к отчёту
   */
  category                 ApplicationCategory @default(EVERYDAY_SUPPORT)
  amount                   Int                 @default(0)
  /// Желаемая сумма сверх лимита уровня — только для администратора, не влияет на экономику
  desiredAmount            Int?
  payment                  String
  /**
   * Нормализованные цифры из payment (>=10) для поиска связанных аккаунтов по всей базе
   */
  paymentFingerprint       String?
  status                   ApplicationStatus   @default(PENDING)
  adminComment             String?
  filledMs                 Int?
  /**
   * Время от первого до последнего изменения поля «Подробная история» (мс); для детекции вставки+ожидания
   */
  storyEditMs              Int?
  submitterIp              String? // IP при подаче заявки (для админки: поиск дублей)
  clientDevice             String? // Устройство при подаче: desktop/android/ios/other
  /// IANA timezone браузера при подаче (Europe/Moscow и т.п.)
  clientTimezone           String?
  /// SHA-256 отпечаток браузера/устройства (антимультиаккаунт)
  deviceFingerprint        String?
  /// Чеклист ручной проверки админа (JSON)
  adminReviewChecklist     String?
  /// Первая бесплатная заявка пользователя
  isFirstFree              Boolean             @default(false)
  /// Списано бонусов за подачу (0 для первой бесплатной)
  submitBonusCost          Int                 @default(0)
  /// Уровень пользователя на момент подачи
  userLevelAtSubmit        Int?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  images            ApplicationImage[]
  bonusTransactions BonusTransaction[]
  likes        StoryLike[]
  comments     StoryComment[]
  review       Review?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([paymentFingerprint])
  @@index([submitterIp])
  @@index([deviceFingerprint])
}

model ApplicationImage {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  url  String
  sort Int

  @@index([applicationId])
  @@index([sort])
}

// Модель для дерева мотивации
model UserTree {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level        Int       @default(0)
  streak       Int       @default(0)
  maxStreak    Int       @default(0)
  totalWatered Int       @default(0)
  lastWatered  DateTime?
  treeType     String? // oak, sakura, etc.
  potType      String? // clay, ceramic, etc.
  background   String? // garden, forest, etc.
  decorations  String? // JSON array of decorations
  isCustomized Boolean   @default(false)
  customizedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

// Модель для дружбы между пользователями
model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User             @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum DonationType {
  SUPPORT // входящий донат/подписка
  PAYOUT // вывод авторам (уменьшает копилку)
  ADJUST // ручная корректировка баланса
}

model Donation {
  id        String       @id @default(cuid())
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      DonationType @default(SUPPORT)
  amount    Int // сумма в рублях (пока), >0
  comment   String?
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model PhoneLoginCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
}

/**
 * Одноразовые токены подтверждения email (в БД хранится только SHA-256 открытого токена).
 */
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Модель для отслеживания времени на страницах
model PageVisit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page      String // путь страницы, например "/applications"
  timeSpent Int // время в миллисекундах
  visitDate DateTime @default(now())

  @@index([userId])
  @@index([page])
  @@index([visitDate])
}

enum StoryReactionType {
  HEART
  THUMBS_UP
  FIRE
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
}

/// Каталог ачивок (определения наполняются из lib/achievements/definitions.ts).
model Achievement {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String
  /// Подсказка для заблокированной ачивки.
  hint        String?
  /// Ключ иконки из LucideIcons, например Sparkles.
  icon        String
  rarity      AchievementRarity @default(COMMON)
  targetValue Int               @default(1)
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userAchievements UserAchievement[]

  @@index([isActive])
  @@index([sortOrder])
}

/// Разблокированные ачивки пользователя.
model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  /// Значение прогресса на момент разблокировки.
  progress      Int         @default(1)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@index([unlockedAt])
}

/// Серия ежедневных визитов на сайт (UTC-дни, как у ежедневного бонуса).
model LoginStreakState {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(0)
  maxStreak     Int      @default(0)
  lastVisitDate String?
  updatedAt     DateTime @updatedAt
}

// Модель для реакций на истории
model StoryLike {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          StoryReactionType @default(HEART)
  createdAt     DateTime          @default(now())

  @@unique([userId, applicationId])
  @@index([userId])
  @@index([applicationId])
  @@index([type])
  @@index([createdAt])
}

/// Комментарии к опубликованным историям (/stories/:id)
model StoryComment {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        StoryComment?  @relation("StoryCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       StoryComment[] @relation("StoryCommentReplies")
  content       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  likes         StoryCommentLike[]

  @@index([applicationId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

/// Лайки комментариев к историям
model StoryCommentLike {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   StoryComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, commentId])
  @@index([userId])
  @@index([commentId])
  @@index([createdAt])
}

model Advertisement {
  id        String    @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  linkUrl   String?
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  placement String    @default("home_sidebar") // home_sidebar, home_banner, stories, other
  config    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([placement])
}

model Review {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?       @unique // заявка, по которой оставлен отзыв (обязательный отзыв между заявками)
  application   Application?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  images        ReviewImage[]

  @@index([userId])
  @@index([applicationId])
  @@index([createdAt])
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String
  sort     Int    @default(0)

  @@index([reviewId])
  @@index([sort])
}

model GoodDeedSubmission {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation("GoodDeedAuthor", fields: [userId], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy   User?   @relation("GoodDeedReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  taskKey         String
  taskTitle       String
  taskDescription String
  weekKey         String
  reward          Int

  /// Рассказ участника о том, как было сделано задание (мин. 100 символов при отправке)
  storyText String @default("")

  status       GoodDeedSubmissionStatus @default(PENDING)
  adminComment String?
  reviewedAt   DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  media GoodDeedSubmissionMedia[]

  @@unique([userId, weekKey, taskKey])
  @@index([status])
  @@index([weekKey])
  @@index([createdAt])
}

model GoodDeedTask {
  id          String   @id
  difficulty  String
  title       String
  description String
  reward      Int
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([difficulty])
  @@index([isActive])
  @@index([sortOrder])
}

model GoodDeedTaskRotationState {
  id             String   @id
  version        Int      @default(0)
  nextRotationAt DateTime
  lastRotatedAt  DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Одна строка (id = singleton): бонус «первый в ленте» выдан навсегда; без FK, чтобы удаление отчёта админом не открывало повторную выдачу
model GoodDeedFirstFeedBonusMeta {
  id           String   @id
  submissionId String   @unique
  bonusBonuses Int      @default(300)
  createdAt    DateTime @default(now())
}

model GoodDeedSubmissionMedia {
  id           String             @id @default(cuid())
  submissionId String
  submission   GoodDeedSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  url          String
  type         GoodDeedMediaType
  sort         Int                @default(0)

  @@index([submissionId])
  @@index([sort])
}

enum GoodDeedWithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

model GoodDeedWithdrawalRequest {
  id                 String                   @id @default(cuid())
  userId             String
  user               User                     @relation("GoodDeedWithdrawalRequester", fields: [userId], references: [id], onDelete: Cascade)
  amountBonuses      Int
  bankName           String
  details            String
  /**
   * Цифры из реквизитов вывода (>=10) — связь с заявками и другими пользователями
   */
  detailsFingerprint String?
  status             GoodDeedWithdrawalStatus @default(PENDING)
  adminComment       String?
  reviewedAt         DateTime?
  reviewedById       String?
  reviewedBy         User?                    @relation("GoodDeedWithdrawalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([detailsFingerprint])
}

model GoodDeedWeekPreference {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekKey         String
  replacedTaskKey String
  newTaskKey      String
  createdAt       DateTime @default(now())

  @@unique([userId, weekKey])
  @@index([userId])
  @@index([weekKey])
}

model GoodDeedBonusGrant {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("GoodDeedBonusGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)
  amountBonuses Int
  comment       String?
  grantedById   String?
  grantedBy     User?    @relation("GoodDeedBonusGrantAdmin", fields: [grantedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([grantedById])
  @@index([createdAt])
}

/// Состояние ежедневного бонуса «Копи любит постоянство» (1 строка на пользователя).
model DailyBonusState {
  userId        String    @id
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Текущая серия после последнего успешного получения бонуса.
  currentStreak Int       @default(0)
  /// Ключ календарного дня UTC (YYYY-MM-DD) последнего получения.
  lastClaimDate String?
  lastClaimAt   DateTime?
  updatedAt     DateTime  @updatedAt
}

/// Журнал получений ежедневного бонуса (защита от повторных запросов за сутки).
model DailyBonusClaim {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimDate      String
  dailyBonus     Int
  milestoneBonus Int      @default(0)
  streakAfter    Int
  createdAt      DateTime @default(now())

  @@unique([userId, claimDate])
  @@index([userId])
  @@index([createdAt])
}

/// Состояние ежедневного сундука (отдельно от «Ежедневного бонуса» в профиле).
model DailyChestState {
  userId        String    @id
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastClaimDate String?
  lastClaimAt   DateTime?
  updatedAt     DateTime  @updatedAt
}

/// Журнал открытий ежедневного сундука.
model DailyChestClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimDate String
  amount    Int
  createdAt DateTime @default(now())

  @@unique([userId, claimDate])
  @@index([userId])
  @@index([createdAt])
}

enum TontineRoundStatus {
  ACTIVE
  FINISHED
}

enum TontineParticipantStatus {
  ALIVE
  ELIMINATED
  WINNER
}

/// Раунд игры «Выживание».
model TontineRound {
  id           String             @id @default(cuid())
  status       TontineRoundStatus @default(ACTIVE)
  roundNumber  Int                @default(1)
  startedAt    DateTime           @default(now())
  finishedAt   DateTime?
  winnerId     String?
  winner       User?              @relation("TontineRoundWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  participants TontineParticipant[]

  @@index([status])
  @@index([startedAt])
}

model TontineParticipant {
  id              String                   @id @default(cuid())
  roundId         String
  round           TontineRound             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId          String
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          TontineParticipantStatus @default(ALIVE)
  joinedAt        DateTime                 @default(now())
  lastCheckInDate String?
  lastCheckInAt   DateTime?
  checkInStreak   Int                      @default(1)
  eliminatedAt    DateTime?
  /** Последняя позиция в мире (пока участник жив). */
  lastWorldX      Float?
  lastWorldY      Float?
  /** Могилка — координаты в момент выбывания. */
  graveWorldX     Float?
  graveWorldY     Float?
  checkIns        TontineCheckIn[]

  @@unique([roundId, userId])
  @@index([roundId, status])
  @@index([userId])
}

model TontineCheckIn {
  id            String             @id @default(cuid())
  participantId String
  participant   TontineParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  checkInDate   String
  createdAt     DateTime           @default(now())

  @@unique([participantId, checkInDate])
  @@index([participantId])
}

// Модель для заявок на размещение рекламы
model AdRequest {
  id               String   @id @default(cuid())
  companyName      String // Название компании/проекта
  email            String // Контактный email
  telegram         String? // Telegram username
  website          String? // Ссылка на сайт/товар
  format           String // Формат размещения (banner, post, telegram)
  duration         Int // Срок в днях
  bannerUrl        String? // URL загруженного баннера (deprecated, используем imageUrls)
  imageUrls        Json? // Массив URL изображений (до 5 штук)
  mobileBannerUrls Json? // Массив URL изображений для мобильного баннера (только для format=banner, до 5 штук)
  comment          String? // Комментарий от рекламодателя
  status           String   @default("new") // new, processing, approved, rejected
  adminComment     String? // Комментарий администратора
  processedBy      String? // ID администратора, обработавшего заявку
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

/// Обратная связь с сайта (попап и страница /feedback).
model SiteFeedback {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  rating      Int?
  message     String
  source      String   @default("popup")
  topic       String   @default("general")
  topicLabel  String?
  pagePath    String?
  status      String   @default("new")
  adminNote   String?
  processedBy String?
  imageUrls   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([topic])
}
